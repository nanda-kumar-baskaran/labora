{
  "name": "labms",
  "version": "0.3.5",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "electron:dev": "concurrently \"next dev --port 3456 --hostname 127.0.0.1\" \"wait-on http://127.0.0.1:3456 && electron .\"",
    "electron:build": "next build && electron-builder build --win --publish never",
    "electron:build:mac": "next build && electron-builder build --mac --publish never",
    "electron:build:linux": "next build && electron-builder build --linux --publish never"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@libsql/client": "^0.17.4",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "docx": "^9.7.1",
    "framer-motion": "^12.42.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.21.0",
    "mammoth": "^1.12.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "recharts": "^3.9.0",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitest/ui": "^3.2.6",
    "concurrently": "^10.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.6",
    "wait-on": "^9.0.10"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "com.labms.desktop",
    "productName": "LabMS",
    "copyright": "Copyright 2024 LabMS",
    "directories": {
      "output": "dist-electron",
      "buildResources": "electron"
    },
    "files": [
      "electron/**/*",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app/.next/standalone",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".next/standalone/node_modules",
        "to": "app/.next/standalone/node_modules",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".next/static",
        "to": "app/.next/standalone/.next/static",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public",
        "to": "app/public",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.ico",
      "artifactName": "LabMS-Setup-${version}.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.icns",
      "category": "public.app-category.medical",
      "artifactName": "LabMS-${version}.dmg"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "electron/icon.png",
      "category": "Science",
      "artifactName": "LabMS-${version}.AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "LabMS",
      "installerIcon": "electron/icon.ico",
      "uninstallerIcon": "electron/icon.ico",
      "installerHeaderIcon": "electron/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "publish": null
  },
  "description": "LabMS \u2014 Laboratory Management System",
  "author": {
    "name": "LabMS",
    "email": "labms@labms.app"
  }
}
