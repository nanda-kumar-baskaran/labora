# Production / Electron build defaults
# NEXT_PUBLIC_* vars are inlined at build time — runtime env overrides don't reach client bundles.
# These ensure the packaged app defaults to offline/local mode out of the box.

STORAGE_MODE=local
NEXT_PUBLIC_APP_URL=http://localhost:3456

# Supabase stubs — unused in local mode but required to satisfy imports
NEXT_PUBLIC_SUPABASE_URL=http://localhost
NEXT_PUBLIC_SUPABASE_ANON_KEY=local
SUPABASE_SERVICE_ROLE_KEY=local
